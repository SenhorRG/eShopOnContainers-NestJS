# --- HTTP in tests / CI ---
# Set "1" when integration or E2E expects plain HTTP service URLs.
ESHOP_USE_HTTP_ENDPOINTS=0

# --- Observability bootstrap (`@eshop/observability`) ---
# OTEL_SDK_DISABLED=true skips NodeSDK (use when no collector or running unit tests without broker).
OTEL_SDK_DISABLED=0
# Optional. Leave unset for dev (defaults to `debug`) / prod (`info`). Empty `LOG_LEVEL=` breaks pino ("default level: must be included in custom levels").
# LOG_LEVEL=info

# --- OpenTelemetry export (optional) ---
# Optional: OTLP collector (see deploy/compose/observability/README.md).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Optional overrides (defaults follow OTEL_EXPORTER_OTLP_ENDPOINT + /v1/{traces|metrics|logs}).
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:14318
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:14318
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:14318
# Default when a process does not set its own name in bootstrap. Each Nest app overrides this with its tracingServiceName unless you set a non-generic OTEL_SERVICE_NAME.
# OTEL_SERVICE_NAME=eshop-nest-local
# Per-process overrides (each Nest binary sets tracingServiceName when unset):
# OTEL_SERVICE_NAME=identity-service
# OTEL_SERVICE_NAME=catalog-service
# OTEL_SERVICE_NAME=ordering-service
# OTEL_SERVICE_NAME=basket-service
# OTEL_SERVICE_NAME=webhooks-service
# OTEL_SERVICE_NAME=mobile-bff
# OTEL_SERVICE_NAME=order-grace-worker
# OTEL_SERVICE_NAME=payment-worker
# OTEL_ENVIRONMENT=development
# OTEL_DIAG_VERBOSE=true

# Comma-separated browser origins for CORS in production (e.g. SPA URL). In non-production, CORS reflects the request origin when this is unset (Vite on http://localhost:5173 → APIs on 127.0.0.1).
# ESHOP_CORS_ORIGINS=https://your-spa.example.com

# Identity seed (`prisma:seed:identity`) — default password for fixture users when unset.
# ESHOP_SEED_USER_PASSWORD=Pass123$

# --- PostgreSQL — logical DBs provisioned via deploy/compose/initdb ---
# Host localhost when developing outside Docker Desktop network.
ESHOP_CATALOG_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/catalogdb
ESHOP_IDENTITY_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/identitydb
ESHOP_ORDERING_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/orderingdb
ESHOP_WEBHOOKS_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/webhooksdb

# --- Redis (basket projections) ---
ESHOP_REDIS_URL=redis://127.0.0.1:56379

# --- Integration event queues (override per deployment) ---
ESHOP_EVENT_BUS_QUEUE_CATALOG=catalog-api
ESHOP_EVENT_BUS_QUEUE_ORDERING=ordering-api
ESHOP_EVENT_BUS_QUEUE_BASKET=basket-api
ESHOP_EVENT_BUS_QUEUE_WEBHOOKS=webhooks-api
ESHOP_EVENT_BUS_QUEUE_ORDER_GRACE=order-grace-worker
ESHOP_EVENT_BUS_QUEUE_PAYMENT=payment-worker

# Publisher retry iterations (broker/socket transient faults)
ESHOP_EVENT_BUS_PUBLISH_RETRY=10

# --- RabbitMQ (integration events) ---
ESHOP_RABBITMQ_HOST=127.0.0.1
ESHOP_RABBITMQ_PORT=55672
ESHOP_RABBITMQ_USERNAME=guest
ESHOP_RABBITMQ_PASSWORD=guest
ESHOP_RABBITMQ_VHOST=/

# --- Service URLs (host-run defaults) ---
ESHOP_IDENTITY_ISSUER_URL=http://localhost:5051
# Shared HS256 secret for identity-service JWT issuance and API validation (ordering, basket, …).
ESHOP_JWT_SYMMETRIC_SECRET=eshop-local-jwt-secret

# --- OIDC (Keycloak study path) — see deploy/keycloak/README.md ---
# When ESHOP_JWT_JWKS_URI is set, basket/ordering/webhooks validate RS256 via JWKS (symmetric secret ignored).
# ESHOP_JWT_JWKS_URI=http://localhost:8081/realms/eshop/protocol/openid-connect/certs
# Comma- or semicolon-separated issuer allow-list (must match token `iss`).
# ESHOP_JWT_ISSUERS=http://localhost:8081/realms/eshop
# Optional audience validation (off by default, mirrors reference AuthenticationExtensions).
# ESHOP_JWT_AUDIENCE=account
# ESHOP_JWT_VALIDATE_AUDIENCE=false
# Disable ordering dev bypass when using Keycloak tokens:
# ESHOP_ORDERING_AUTH_BYPASS=0
# Basket: HTTP uses PORT (default 5054); gRPC uses GRPC_PORT (default 9071). Clients must target gRPC, not HTTP.
# GRPC_PORT=9071
ESHOP_BASKET_GRPC_URL=127.0.0.1:9071
ESHOP_MOBILE_BFF_URL=http://localhost:5070
ESHOP_WEBHOOKS_API_URL=http://localhost:5055
ESHOP_CATALOG_HTTP_URL=http://localhost:5052
ESHOP_ORDERING_HTTP_URL=http://localhost:5053

# Catalog static pics. Omit for default: apps/catalog-service/assets/pics (relative to service cwd).
# Docker stack sets CATALOG_PICS_PATH=/data/catalog/pics (volume from apps/catalog-service/assets/pics).
# Do not set to empty: CATALOG_PICS_PATH= breaks join() and GET /items/:id/pic returns 404.
# CATALOG_PICS_PATH=apps/catalog-service/assets/pics

# --- Catalog embeddings ---
# When "1"/"true", Ollama client is preferred over OpenAI-compatible HTTP.
ESHOP_CATALOG_OLLAMA_ENABLED=0
ESHOP_OLLAMA_BASE_URL=http://127.0.0.1:11434
ESHOP_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Catalog chat (Ollama proxy) ---
# When "1"/"true", POST /api/catalog/chat/completions proxies to Ollama (requires ESHOP_OLLAMA_BASE_URL).
ESHOP_CATALOG_CHAT_ENABLED=0
ESHOP_CATALOG_CHAT_MODEL=llama3.2

# Enable OpenAI-style embeddings HTTP when key/URL exist (vectors truncated to Postgres vector(384)).
ESHOP_OPENAI_EMBEDDINGS_API_KEY=
ESHOP_OPENAI_EMBEDDINGS_URL=https://api.openai.com/v1/embeddings
ESHOP_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# --- Storefront (Vite) — copy into apps/storefront-web/.env.local as needed ---
# VITE_ESHOP_CATALOG_ORIGIN=http://127.0.0.1:5052
# VITE_ESHOP_ORDERING_ORIGIN=http://127.0.0.1:5053
# VITE_ESHOP_IDENTITY_ORIGIN=http://127.0.0.1:5051
# VITE_ESHOP_BFF_ORIGIN=http://127.0.0.1:5070

# --- Mobile BFF rate limit (@nestjs/throttler) ---
# ESHOP_BFF_THROTTLE_TTL_MS=60000
# ESHOP_BFF_THROTTLE_LIMIT=120
# VITE_ESHOP_AUTHORITY=http://localhost:8081/realms/eshop
# VITE_ESHOP_CLIENT_ID=webapp
# VITE_ESHOP_STOREFRONT_BASE=/
# VITE_ESHOP_HIDE_CHATBOT=true

# --- Webhook client (Vite, http://localhost:5174) — also apps/webhook-client/.env.example ---
# VITE_ESHOP_IDENTITY_ORIGIN=http://127.0.0.1:5051
# VITE_ESHOP_WEBHOOKS_ORIGIN=http://127.0.0.1:5055
# Prefill login email (must match identity seed user webhooks-dev@eshop.local). Password: ESHOP_SEED_USER_PASSWORD below.
# VITE_ESHOP_DEV_LOGIN_EMAIL=webhooks-dev@eshop.local
# VITE_WEBHOOK_RECEIVER_ORIGIN=http://127.0.0.1:8788
# VITE_WEBHOOK_DEFAULT_TOKEN=

# --- Operations hub (Vite http://localhost:5188; embedded Loki/Jaeger/Prometheus via dev proxy) ---
# VITE_ESHOP_GRAFANA_URL=http://localhost:3200
# VITE_ESHOP_PROMETHEUS_URL=http://localhost:9099
# VITE_ESHOP_LOKI_URL=http://localhost:3100
# VITE_ESHOP_JAEGER_URL=http://localhost:16686
# Default service rows: apps/operations-dashboard/src/catalog/local-nest-services.json
# VITE_ESHOP_OPS_SERVICES_JSON=[{"id":"catalog","title":"catalog-service","healthUrl":"http://127.0.0.1:5052/api/health"}]
# PORT=
