# Stack profile — merge with base compose:
#   docker compose -f docker-compose.yml -f docker-compose.stack.yml --env-file .env.stack.example --profile stack up -d --build
#
# Base infra ports (host): Postgres 55432, Redis 56379, Rabbit 55672 — see docker-compose.yml

COMPOSE_PROJECT_NAME=eshop-nestjs
COMPOSE_PROFILES=stack

# Catalog AI / embeddings (keep off in stack unless you wire providers)
ESHOP_CATALOG_EMBEDDINGS_PROVIDER=off

# Dev-only secrets (replace in real deployments)
ESHOP_ORDERING_JWT_SECRET=ordering-stack-secret
ESHOP_BASKET_JWT_SECRET=basket-stack-secret

# Identity signs JWTs with ESHOP_JWT_SYMMETRIC_SECRET in code; compose.stack mirrors ordering secret for stack alignment.
# Issuer string embedded in tokens (browser-visible stack URL).
ESHOP_IDENTITY_ISSUER_URL=http://127.0.0.1:5051

# Baked into storefront static assets at image build (browser calls host-published ports).
VITE_ESHOP_IDENTITY_ORIGIN=http://127.0.0.1:5051
VITE_ESHOP_CATALOG_ORIGIN=http://127.0.0.1:5052
VITE_ESHOP_ORDERING_ORIGIN=http://127.0.0.1:5053

# mobile-bff → identity upstream (Compose DNS). Set ESHOP_BFF_PROXY_IDENTITY_ENABLED=false to disable.
ESHOP_BFF_PROXY_IDENTITY_ENABLED=true
ESHOP_BFF_PROXY_IDENTITY_URL=http://identity-service:5051

# Local study only: skip JWT on Ordering REST when "1".
ESHOP_ORDERING_AUTH_BYPASS=1

# Local study only: skip real JWT on Webhooks when "1" (demo / webhook-client).
ESHOP_WEBHOOKS_AUTH_BYPASS=1
