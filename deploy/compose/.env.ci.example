# Example matrix for CI / Playwright — copy to `.env.ci` and adjust.
# Plain HTTP for tests when combined with `ESHOP_USE_HTTP_ENDPOINTS=1`.

COMPOSE_PROFILES=infra-only

# Same project name as docker-compose.yml / .env.compose.example so CI containers match local naming.
COMPOSE_PROJECT_NAME=eshop-nestjs

# Plain HTTP service URLs (storefront / integration tests)
ESHOP_USE_HTTP_ENDPOINTS=1

# Catalog embeddings off in CI unless snapshot tests cover AI (avoid flaky outbound calls)
ESHOP_CATALOG_EMBEDDINGS_PROVIDER=off

# Canonical Postgres URL for Nest apps when binding to compose-ci ports (host networking from runner)
# ESHOP_CATALOG_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/catalogdb
