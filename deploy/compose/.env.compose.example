# Copy to `.env` in this directory for local overrides.
# Compose auto-loads `.env` from the project directory when using --project-directory.

COMPOSE_PROJECT_NAME=eshop-nestjs

# `dev` → Postgres + Redis + RabbitMQ plus observability stack when merged with
# `observability/docker-compose.observability.yml` (see root `pnpm infra:up`).
COMPOSE_PROFILES=dev

# Optional RabbitMQ tuning (defaults match reference dev guest/guest)
# RABBITMQ_DEFAULT_USER=guest
# RABBITMQ_DEFAULT_PASS=guest
