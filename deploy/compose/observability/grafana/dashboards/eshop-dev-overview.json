{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "external link",
      "targetBlank": true,
      "title": "Jaeger traces",
      "type": "link",
      "url": "http://localhost:16686/search?service=${service}"
    },
    {
      "icon": "external link",
      "targetBlank": true,
      "title": "Loki logs",
      "type": "link",
      "url": "http://localhost:3200/explore?orgId=1&left=%7B%22datasource%22:%22loki%22,%22queries%22:%5B%7B%22expr%22:%22%7Bservice_name%3D%5C%22${service}%5C%22%7D%22%7D%5D%7D"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "mode": "markdown",
        "content": "HTTP RED and RabbitMQ integration metrics for local Nest services."
      },
      "title": "Notes",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "down" } }, "type": "value" },
            { "options": { "from": 1, "result": { "color": "green", "index": 1, "text": "up" }, "to": 1 }, "type": "range" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 4 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "up{job=\"otel-collector\"}", "refId": "A" }],
      "title": "OTEL collector scrape",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{exported_job=~\"$service\"}[5m])) by (exported_job)",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, exported_job) (rate(http_server_duration_milliseconds_bucket{exported_job=~\"$service\",http_status_code=\"200\"}[5m])))",
          "legendFormat": "{{exported_job}} p95",
          "refId": "A"
        }
      ],
      "title": "HTTP latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0",
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{exported_job=~\"$service\",http_status_code=~\"5..\"}[5m])) by (exported_job) or (sum(rate(http_server_duration_milliseconds_count{exported_job=~\"$service\"}[5m])) by (exported_job) * 0)",
          "legendFormat": "{{exported_job}} 5xx",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "noValue": "0",
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(eshop_eventbus_publish_duration_ms_count{exported_job=~\"$service\"}[5m])) by (exported_job) or (sum(rate(http_server_duration_milliseconds_count{exported_job=~\"$service\"}[5m])) by (exported_job) * 0)",
          "legendFormat": "{{exported_job}} publish",
          "refId": "A"
        },
        {
          "expr": "sum(rate(eshop_eventbus_consume_process_duration_ms_count{exported_job=~\"$service\"}[5m])) by (exported_job) or (sum(rate(http_server_duration_milliseconds_count{exported_job=~\"$service\"}[5m])) by (exported_job) * 0)",
          "legendFormat": "{{exported_job}} consume",
          "refId": "B"
        }
      ],
      "title": "Integration bus throughput (OTLP custom meters)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["eshop-nestjs", "eshop-dev"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prom" },
        "definition": "label_values(http_server_duration_milliseconds_count, exported_job)",
        "includeAll": true,
        "label": "service",
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(http_server_duration_milliseconds_count, exported_job)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "eShop Nest Overview",
  "uid": "eshop-dev-overview",
  "version": 4
}
