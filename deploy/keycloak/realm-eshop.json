{
  "realm": "eshop",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "roles": {
    "realm": [
      { "name": "user", "description": "Default storefront user" }
    ]
  },
  "clients": [
    {
      "clientId": "webapp",
      "name": "eShop Storefront",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:5173",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*##http://127.0.0.1:5173/*"
      },
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    },
    {
      "clientId": "mobile",
      "name": "eShop Mobile BFF study client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["eshop://callback", "http://localhost:5070/*"],
      "webOrigins": ["+"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"]
    }
  ],
  "users": [
    {
      "username": "alice@example.com",
      "email": "alice@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Pass123$",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}
