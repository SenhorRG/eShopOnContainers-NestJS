# Copy to `.env.local` in this folder (Vite loads it automatically).
# Local accounts: identity-service on VITE_ESHOP_IDENTITY_ORIGIN (default http://127.0.0.1:5051).
# Optional OIDC: set VITE_ESHOP_AUTHORITY + VITE_ESHOP_CLIENT_ID to use Duende / external IdP instead.

VITE_ESHOP_CATALOG_ORIGIN=http://127.0.0.1:5052
VITE_ESHOP_ORDERING_ORIGIN=http://127.0.0.1:5053
VITE_ESHOP_IDENTITY_ORIGIN=http://127.0.0.1:5051
VITE_ESHOP_BFF_ORIGIN=http://127.0.0.1:5070

# When set, /user/login redirects to Identity (Duende) for login/register; callback: /auth/callback
# Example with Aspire / eShop-main Identity.API (adjust port to your launch profile)
# VITE_ESHOP_AUTHORITY=http://localhost:5223
# VITE_ESHOP_CLIENT_ID=webapp

# Optional — force sessionStorage cart even when logged in (default: basket-service via BFF when authenticated)
# VITE_ESHOP_CART_GUEST_MODE=true

# Optional
# VITE_ESHOP_STOREFRONT_BASE=/
# VITE_ESHOP_HIDE_CHATBOT=true
