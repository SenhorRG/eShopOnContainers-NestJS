{
  "name": "@eshop/catalog-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "build": "pnpm run prisma:generate && nest build",
    "start": "nest start",
    "start:dev": "pnpm exec prisma generate --schema prisma/schema.prisma && nest start --watch",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:unit": "jest --config jest.config.unit.json --passWithNoTests",
    "test:e2e": "jest --config jest-e2e.json"
  },
  "dependencies": {
    "@eshop/catalog-domain": "workspace:*",
    "@eshop/event-bus-amqp": "workspace:*",
    "@eshop/inbox": "workspace:*",
    "@eshop/health": "workspace:*",
    "@eshop/http-resilience": "workspace:*",
    "@eshop/integration-event-types": "workspace:*",
    "@eshop/openapi-common": "workspace:*",
    "@eshop/observability": "workspace:*",
    "@eshop/outbox": "workspace:*",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.3",
    "@prisma/client": "^6.3.1",
    "axios": "^1.8.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/testing": "^11.0.11",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "@types/supertest": "^6.0.2",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  }
}
