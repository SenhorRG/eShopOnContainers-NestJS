{
  "name": "@eshop/webhooks-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "build": "pnpm run prisma:generate && nest build",
    "start": "nest start",
    "start:dev": "pnpm exec prisma generate --schema prisma/schema.prisma && nest start --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@eshop/auth": "workspace:*",
    "@eshop/event-bus-amqp": "workspace:*",
    "@eshop/health": "workspace:*",
    "@eshop/http-resilience": "workspace:*",
    "@eshop/inbox": "workspace:*",
    "@eshop/integration-event-types": "workspace:*",
    "@eshop/openapi-common": "workspace:*",
    "@eshop/observability": "workspace:*",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.3",
    "@prisma/client": "^6.3.1",
    "axios": "^1.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.14",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
