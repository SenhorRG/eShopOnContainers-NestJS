generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/identity-prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("ESHOP_IDENTITY_DATABASE_URL")
}

model IdentityUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())

  @@map("IdentityUsers")
}
